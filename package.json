{
  "name": "cabo-client",
  "version": "1.9.0",
  "private": true,
  "packageManager": "npm@12.0.1",
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=12.0.1 <13"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@ant-design/icons": "6.3.2",
    "@ant-design/nextjs-registry": "1.3.0",
    "@stomp/stompjs": "7.3.0",
    "antd": "6.5.1",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sockjs-client": "1.6.1"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/sockjs-client": "1.5.4",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prettier": "3.9.5",
    "typescript": "6.0.3"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  },
  "overrides": {
    "postcss": "8.5.10",
    "websocket-driver": "0.7.5"
  }
}
